 @{
    ViewData["Title"] = "Find Your Perfect Tutor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
/* ══════════════════════════════════════════
   NAVBAR
══════════════════════════════════════════ */
.navbar-custom {
    position: fixed; top: 0; left: 0; right: 0; z-index: 999;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 52px;
    background: rgba(13,10,30,0.55);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: background 0.3s;
}
.nav-logo {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700; color: #fff;
}
.nav-logo-icon {
    width: 38px; height: 38px; border-radius: 10px;
    background: linear-gradient(135deg, #7c5cfc, #06b6d4);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
}
.nav-logo span { color: var(--accent2); }
.nav-links { display: flex; align-items: center; gap: 30px; list-style: none; margin: 0; padding: 0; }
.nav-links a { color: rgba(255,255,255,0.62); font-size: 14px; transition: color 0.2s; }
.nav-links a:hover { color: #fff; }
.nav-cta {
    padding: 10px 26px; background: var(--accent2);
    color: #0d0a1e !important; border-radius: 999px; font-weight: 500 !important;
    transition: opacity 0.2s;
}
.nav-cta:hover { opacity: 0.88; }
@@media (max-width: 768px) {
    .navbar-custom { padding: 14px 20px; }
    .nav-links { display: none; }
}

/* ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ */
.hero {
    position: relative; min-height: 100vh;
    background: #0d0a1e;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    overflow: hidden; padding: 100px 24px 60px;
    text-align: center;
}
/* background image layer using a free Unsplash photo */
.hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1600&q=80');
    background-size: cover; background-position: center;
    opacity: 0.08;
}
.blob {
    position: absolute; border-radius: 50%;
    filter: blur(90px); pointer-events: none;
    animation: drift 14s ease-in-out infinite alternate;
}
.blob-1 { width:520px;height:520px;background:#7c5cfc;opacity:.4;top:-160px;left:-140px;animation-duration:16s; }
.blob-2 { width:400px;height:400px;background:#06b6d4;opacity:.32;bottom:-110px;right:-90px;animation-duration:12s;animation-delay:-4s; }
.blob-3 { width:260px;height:260px;background:#e8f97d;opacity:.09;top:55%;left:14%;animation-duration:20s;animation-delay:-9s; }
@@keyframes drift {
    0%   { transform:translate(0,0) scale(1); }
    50%  { transform:translate(28px,-18px) scale(1.07); }
    100% { transform:translate(-18px,28px) scale(.95); }
}
.hero::after {
    content:''; position:absolute; inset:0; z-index:0;
    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);
    background-size:56px 56px; pointer-events:none;
}
.hero-inner { position:relative; z-index:2; max-width:840px; }

.hero-badge {
    display:inline-flex; align-items:center; gap:8px;
    background:var(--glass); border:1px solid var(--glass-border);
    border-radius:999px; padding:8px 20px;
    color:rgba(255,255,255,.8); font-size:12px;
    letter-spacing:.07em; text-transform:uppercase;
    margin-bottom:32px; backdrop-filter:blur(6px);
    animation:fadeUp .7s ease both;
}
.badge-dot { width:7px;height:7px;background:var(--accent2);border-radius:50%;animation:pulse 2s infinite; }
@@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)} }

.hero h1 {
    font-family:'Playfair Display',serif;
    font-size:clamp(46px,8vw,88px); font-weight:900;
    line-height:1.05; color:#fff; margin-bottom:24px;
    animation:fadeUp .7s .1s ease both;
}
.hero h1 em {
    font-style:normal;
    background:linear-gradient(90deg,#a78bfa,#06b6d4,#e8f97d);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.hero p {
    font-size:clamp(16px,2.2vw,20px); color:rgba(255,255,255,.55);
    font-weight:300; max-width:520px; margin:0 auto 42px; line-height:1.8;
    animation:fadeUp .7s .2s ease both;
}
.hero-cta { display:inline-flex; gap:14px; flex-wrap:wrap; justify-content:center; animation:fadeUp .7s .3s ease both; }

.btn-primary-custom {
    padding:16px 40px; background:var(--accent2); color:#0d0a1e;
    border-radius:999px; font-weight:500; font-size:16px;
    transition:transform .2s, box-shadow .2s; display:inline-block;
}
.btn-primary-custom:hover { transform:translateY(-2px); box-shadow:0 10px 32px rgba(232,249,125,.35); color:#0d0a1e; }
.btn-ghost {
    padding:16px 40px; background:transparent; color:rgba(255,255,255,.85);
    border-radius:999px; font-weight:400; font-size:16px;
    border:1px solid var(--glass-border); transition:background .2s; display:inline-block;
}
.btn-ghost:hover { background:var(--glass); color:#fff; }

.stat-strip {
    position:relative; z-index:2;
    display:flex; justify-content:center; gap:14px; flex-wrap:wrap;
    margin-top:60px; animation:fadeUp .7s .4s ease both;
}
.stat-pill {
    background:var(--glass); border:1px solid var(--glass-border);
    border-radius:16px; padding:16px 26px; text-align:center;
    backdrop-filter:blur(10px); color:#fff;
}
.stat-pill strong {
    display:block; font-family:'Playfair Display',serif;
    font-size:28px; font-weight:700; color:var(--accent2);
    line-height:1; margin-bottom:4px;
}
.stat-pill span { font-size:11px; color:rgba(255,255,255,.45); text-transform:uppercase; letter-spacing:.08em; }

@@keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }

.scroll-hint {
    position:absolute; bottom:32px; left:50%; transform:translateX(-50%);
    z-index:2; display:flex; flex-direction:column; align-items:center; gap:8px;
    color:rgba(255,255,255,.28); font-size:11px; letter-spacing:.1em; text-transform:uppercase;
}
.scroll-line {
    width:1px; height:40px;
    background:linear-gradient(to bottom,rgba(255,255,255,.4),transparent);
    animation:scrollLine 2s ease-in-out infinite;
}
@@keyframes scrollLine {
    0%{transform:scaleY(0);transform-origin:top}
    50%{transform:scaleY(1);transform-origin:top}
    51%{transform:scaleY(1);transform-origin:bottom}
    100%{transform:scaleY(0);transform-origin:bottom}
}

/* ══════════════════════════════════════════
   LOGO STRIP (trusted by)
══════════════════════════════════════════ */
.logo-strip {
    background:#0d0a1e; padding:40px 24px;
    border-top:1px solid rgba(255,255,255,.06);
    border-bottom:1px solid rgba(255,255,255,.06);
}
.logo-strip-inner { max-width:1100px; margin:auto; text-align:center; }
.logo-strip p {
    font-size:12px; text-transform:uppercase; letter-spacing:.1em;
    color:rgba(255,255,255,.28); margin-bottom:28px;
}
.logos { display:flex; align-items:center; justify-content:center; gap:40px; flex-wrap:wrap; }
.logo-badge {
    display:flex; align-items:center; gap:10px;
    color:rgba(255,255,255,.35); font-size:15px; font-weight:500;
    font-family:'Playfair Display',serif; letter-spacing:.03em;
    transition:color .2s;
}
.logo-badge:hover { color:rgba(255,255,255,.7); }
.logo-badge-icon {
    width:36px; height:36px; border-radius:8px;
    display:flex; align-items:center; justify-content:center; font-size:18px;
    background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.09);
}

/* ══════════════════════════════════════════
   FEATURES
══════════════════════════════════════════ */
.features {
    padding:110px 24px; background:var(--cream);
    position:relative; overflow:hidden;
}
.features::before {
    content:''; position:absolute; width:600px;height:600px; border-radius:50%;
    background:radial-gradient(circle,rgba(124,92,252,.07),transparent 70%);
    top:-200px; right:-200px; pointer-events:none;
}
.features::after {
    content:''; position:absolute; width:400px;height:400px; border-radius:50%;
    background:radial-gradient(circle,rgba(6,182,212,.06),transparent 70%);
    bottom:-100px; left:-100px; pointer-events:none;
}
.features-inner { max-width:1140px; margin:auto; position:relative; z-index:1; }
.section-label {
    display:inline-block; font-size:12px; font-weight:500;
    letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:14px;
}
.section-title {
    font-family:'Playfair Display',serif;
    font-size:clamp(34px,5vw,56px); font-weight:700;
    line-height:1.1; color:var(--ink); margin-bottom:14px;
}
.section-sub {
    font-size:17px; color:#6b6a78; font-weight:300;
    max-width:480px; line-height:1.8; margin-bottom:68px;
}
.cards-grid {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:22px;
}
.card {
    background:#fff; border-radius:26px; padding:42px 34px;
    position:relative; overflow:hidden;
    border:1px solid rgba(0,0,0,.06);
    transition:transform .3s, box-shadow .3s;
}
.card:hover { transform:translateY(-6px); box-shadow:0 24px 60px rgba(0,0,0,.1); }
.card::before {
    content:''; position:absolute; top:0;right:0;
    width:100px;height:100px; border-radius:0 26px 0 100%;
}
.card-1::before{background:linear-gradient(135deg,#7c5cfc22,#7c5cfc11)}
.card-2::before{background:linear-gradient(135deg,#06b6d422,#06b6d411)}
.card-3::before{background:linear-gradient(135deg,#e8f97d44,#e8f97d22)}
.card-4::before{background:linear-gradient(135deg,#f472b644,#f472b622)}
.card-5::before{background:linear-gradient(135deg,#34d39922,#34d39911)}
.card-6::before{background:linear-gradient(135deg,#fb923c22,#fb923c11)}
.card-icon {
    width:54px;height:54px; border-radius:14px;
    display:flex;align-items:center;justify-content:center;
    font-size:26px; margin-bottom:26px;
}
.icon-purple{background:#ede9fe} .icon-cyan{background:#cffafe}
.icon-lime{background:#f7fee7}   .icon-pink{background:#fce7f3}
.icon-green{background:#d1fae5}  .icon-orange{background:#ffedd5}
.card h3 { font-family:'Playfair Display',serif; font-size:21px; font-weight:700; color:var(--ink); margin-bottom:10px; }
.card p  { font-size:15px; color:#7c7b8a; line-height:1.7; font-weight:300; }
.card-link {
    display:inline-flex; align-items:center; gap:6px;
    margin-top:22px; font-size:14px; font-weight:500;
    color:var(--accent); transition:gap .2s;
}
.card-link:hover { gap:10px; color:var(--accent); }

/* ══════════════════════════════════════════
   HOW IT WORKS
══════════════════════════════════════════ */
.how {
    padding:110px 24px;
    background: #0d0a1e;
    position:relative; overflow:hidden;
}
.how::before {
    content:''; position:absolute; inset:0;
    background-image: url('https://images.unsplash.com/photo-1571260899304-425eee4c7efc?w=1600&q=80');
    background-size:cover; background-position:center; opacity:.05;
}
.how-inner { max-width:1100px; margin:auto; position:relative; z-index:1; }
.how .section-label { color:var(--accent2); }
.how .section-title { color:#fff; }
.how .section-sub   { color:rgba(255,255,255,.45); }
.steps-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:2px; margin-top:60px; }
.step-card {
    background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
    padding:40px 30px; position:relative;
    transition:background .3s;
}
.step-card:first-child { border-radius:20px 0 0 20px; }
.step-card:last-child  { border-radius:0 20px 20px 0; }
.step-card:hover { background:rgba(255,255,255,.08); }
.step-num-big {
    font-family:'Playfair Display',serif;
    font-size:64px; font-weight:900;
    color:rgba(255,255,255,.06); line-height:1;
    margin-bottom:16px;
}
.step-card h4 { font-family:'Playfair Display',serif; font-size:19px; font-weight:700; color:#fff; margin-bottom:10px; }
.step-card p  { font-size:14px; color:rgba(255,255,255,.45); line-height:1.7; font-weight:300; }
.step-icon { font-size:32px; margin-bottom:14px; }

/* ══════════════════════════════════════════
   CTA BAND
══════════════════════════════════════════ */
.cta-band {
    padding:100px 24px; text-align:center;
    background:var(--cream); position:relative; overflow:hidden;
}
.cta-band::before {
    content:''; position:absolute; inset:0;
    background:radial-gradient(ellipse 70% 50% at 50% 100%,rgba(124,92,252,.12),transparent);
    pointer-events:none;
}
.cta-band h2 {
    font-family:'Playfair Display',serif;
    font-size:clamp(34px,6vw,58px); font-weight:700;
    color:var(--ink); margin-bottom:18px; position:relative;
}
.cta-band p { color:#6b6a78; font-size:17px; margin-bottom:38px; position:relative; font-weight:300; }

/* ══════════════════════════════════════════
   FOOTER
══════════════════════════════════════════ */
.footer {
    background:#0d0a1e; padding:60px 24px 30px;
    border-top:1px solid rgba(255,255,255,.06);
}
.footer-inner {
    max-width:1140px; margin:auto;
    display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:40px;
}
@@media(max-width:768px){ .footer-inner{grid-template-columns:1fr 1fr} }
@@media(max-width:480px){ .footer-inner{grid-template-columns:1fr} }
.footer-brand { }
.footer-brand .logo {
    display:flex; align-items:center; gap:10px; margin-bottom:16px;
    font-family:'Playfair Display',serif; font-size:20px; font-weight:700; color:#fff;
}
.footer-brand .logo span { color:var(--accent2); }
.footer-brand p { font-size:14px; color:rgba(255,255,255,.38); line-height:1.7; max-width:240px; font-weight:300; }
.footer-col h5 {
    font-size:12px; font-weight:500; text-transform:uppercase;
    letter-spacing:.1em; color:rgba(255,255,255,.4); margin-bottom:18px;
}
.footer-col a {
    display:block; font-size:14px; color:rgba(255,255,255,.5);
    margin-bottom:10px; transition:color .2s;
}
.footer-col a:hover { color:#fff; }
.footer-bottom {
    max-width:1140px; margin:40px auto 0;
    padding-top:24px; border-top:1px solid rgba(255,255,255,.06);
    display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;
}
.footer-bottom p { font-size:13px; color:rgba(255,255,255,.25); }
</style>

<!-- ═══ NAVBAR ═══ -->
<nav class="navbar-custom">
    <a asp-action="Index" asp-controller="Home" class="nav-logo">
        <div class="nav-logo-icon">🎓</div>
        Tutor<span>Sphere</span>
    </a>
    <ul class="nav-links">
        <li><a asp-action="Index"   asp-controller="Home">Home</a></li>
        <li><a asp-action="Index"   asp-controller="Tutors">Tutors</a></li>
        <li><a asp-action="HowItWorks"   asp-controller="Info">How It Works</a></li>
        <partial name="_AuthNav" />
        <li><a asp-action="Index"   asp-controller="Booking" class="nav-cta">Book Now</a></li>
    </ul>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="hero-inner">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            1,200+ Expert Tutors Online Now
        </div>

        <h1>
            Learn from the<br/>
            <em>Brightest Minds</em>
        </h1>

        <p>
            Connect with world-class tutors for personalized one-on-one sessions —
            any subject, any pace, anywhere in the world.
        </p>

        <div class="hero-cta">
            <a asp-action="Index" asp-controller="Tutors" class="btn-primary-custom">Explore Tutors →</a>
            <a asp-action="Index" asp-controller="Booking" class="btn-ghost">Book a Session</a>
        </div>
    </div>

    <div class="stat-strip">
        <div class="stat-pill"><strong>50K+</strong><span>Students Taught</span></div>
        <div class="stat-pill"><strong>98%</strong><span>Satisfaction Rate</span></div>
        <div class="stat-pill"><strong>120+</strong><span>Subjects Covered</span></div>
        <div class="stat-pill"><strong>4.9★</strong><span>Average Rating</span></div>
    </div>

    <div class="scroll-hint">
        <div class="scroll-line"></div>
        Scroll
    </div>
</section>

<!-- ═══ LOGO STRIP ═══ -->
<div class="logo-strip">
    <div class="logo-strip-inner">
        <p>Trusted by students from leading institutions</p>
        <div class="logos">
            <div class="logo-badge"><div class="logo-badge-icon">🏛️</div> Oxford Alumni</div>
            <div class="logo-badge"><div class="logo-badge-icon">🎯</div> MIT Scholars</div>
            <div class="logo-badge"><div class="logo-badge-icon">⚡</div> Stanford Prep</div>
            <div class="logo-badge"><div class="logo-badge-icon">🌐</div> Cambridge Trust</div>
            <div class="logo-badge"><div class="logo-badge-icon">🏆</div> IVY Connect</div>
        </div>
    </div>
</div>

<!-- ═══ FEATURES ═══ -->
<section class="features">
    <div class="features-inner">
        <span class="section-label">Why TutorSphere</span>
        <h2 class="section-title">Everything you need<br/>to learn smarter</h2>
        <p class="section-sub">We built the platform we wished we had — intuitive, flexible, and genuinely effective.</p>

        <div class="cards-grid">
            <div class="card card-1">
                <div class="card-icon icon-purple">🎓</div>
                <h3>Expert Tutors</h3>
                <p>Every tutor is vetted through a rigorous review. You get only the best — PhDs, professionals, and award-winning educators.</p>
                <a asp-action="Index" asp-controller="Tutors" class="card-link">Browse tutors →</a>
            </div>
            <div class="card card-2">
                <div class="card-icon icon-cyan">⚡</div>
                <h3>Instant Booking</h3>
                <p>Find and book a session in under 60 seconds. Real-time availability, zero back-and-forth, instant confirmation.</p>
                <a asp-action="Index" asp-controller="Booking" class="card-link">Book now →</a>
            </div>
            <div class="card card-3">
                <div class="card-icon icon-lime">💡</div>
                <h3>Personalized Learning</h3>
                <p>Sessions adapt to your goals, learning style, and pace. No cookie-cutter curriculum — only what you actually need.</p>
                <a asp-action="Index" asp-controller="Home" class="card-link">See how →</a>
            </div>
            <div class="card card-4">
                <div class="card-icon icon-pink">🔒</div>
                <h3>Safe &amp; Secure</h3>
                <p>All sessions happen on our encrypted platform. Payments are protected and sessions recorded for your peace of mind.</p>
                <a asp-action="Index" asp-controller="Home" class="card-link">Learn more →</a>
            </div>
            <div class="card card-5">
                <div class="card-icon icon-green">📈</div>
                <h3>Track Progress</h3>
                <p>Visual dashboards show your improvement week by week. Goals, milestones, and insights all in one place.</p>
                <a asp-action="Index" asp-controller="Home" class="card-link">See dashboard →</a>
            </div>
            <div class="card card-6">
                <div class="card-icon icon-orange">🌍</div>
                <h3>Learn Anywhere</h3>
                <p>Native mobile apps for iOS and Android. Start a session from your bedroom, a café, or anywhere in the world.</p>
                <a asp-action="Index" asp-controller="Home" class="card-link">Get the app →</a>
            </div>
        </div>
    </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="how">
    <div class="how-inner">
        <span class="section-label">Simple Process</span>
        <h2 class="section-title">Up and running<br/>in 3 easy steps</h2>
        <p class="section-sub">From signup to your first session in minutes — no complicated setup.</p>

        <div class="steps-grid">
            <div class="step-card">
                <div class="step-num-big">01</div>
                <div class="step-icon">🔍</div>
                <h4>Find Your Tutor</h4>
                <p>Browse by subject, rating, price, or availability. Read reviews from real students.</p>
            </div>
            <div class="step-card">
                <div class="step-num-big">02</div>
                <div class="step-icon">📅</div>
                <h4>Book a Session</h4>
                <p>Pick a time slot that works for you and confirm instantly. No waiting for approval.</p>
            </div>
            <div class="step-card">
                <div class="step-num-big">03</div>
                <div class="step-icon">🚀</div>
                <h4>Start Learning</h4>
                <p>Join your session via our built-in video platform. Interactive tools included.</p>
            </div>
            <div class="step-card">
                <div class="step-num-big">04</div>
                <div class="step-icon">📈</div>
                <h4>Track &amp; Improve</h4>
                <p>Get session summaries, homework, and progress reports after every class.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══ CTA BAND ═══ -->
<section class="cta-band">
    <h2>Ready to start learning?</h2>
    <p>Join 50,000+ students already leveling up with TutorSphere.</p>
    <a asp-action="Index" asp-controller="Booking" class="btn-primary-custom">Book Your First Session →</a>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <div class="logo">
                <span style="font-size:24px">🎓</span>
                Tutor<span>Sphere</span>
            </div>
            <p>World-class tutoring, made accessible to every student, everywhere.</p>
