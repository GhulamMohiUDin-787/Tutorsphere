 @{
    ViewData["Title"] = "Find a Tutor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
/* ══════════════════════════════════════════
   NAVBAR
══════════════════════════════════════════ */
.navbar-custom{
    position:fixed;top:0;left:0;right:0;z-index:999;
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 52px;
    background:rgba(13,10,30,0.55);
    backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(255,255,255,0.07);
}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#fff;}
.nav-logo-icon{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#7c5cfc,#06b6d4);display:flex;align-items:center;justify-content:center;font-size:20px;}
.nav-logo span{color:var(--accent2);}
.nav-links{display:flex;align-items:center;gap:30px;list-style:none;margin:0;padding:0;}
.nav-links a{color:rgba(255,255,255,.62);font-size:14px;transition:color .2s;}
.nav-links a:hover{color:#fff;}
.nav-cta{padding:10px 26px;background:var(--accent2);color:#0d0a1e !important;border-radius:999px;font-weight:500 !important;}
@@media(max-width:768px){.navbar-custom{padding:14px 20px;}.nav-links{display:none;}}

/* ══════════════════════════════════════════
   PAGE HERO
══════════════════════════════════════════ */
.tutors-hero{
    position:relative;padding:160px 24px 80px;
    background:#0d0a1e;text-align:center;overflow:hidden;
}
.tutors-hero-bg{
    position:absolute;inset:0;
    background-image:url('https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1600&q=80');
    background-size:cover;background-position:center;opacity:.06;
}
.blob{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none;animation:drift 14s ease-in-out infinite alternate;}
.blob-1{width:500px;height:500px;background:#7c5cfc;opacity:.35;top:-150px;left:-130px;animation-duration:16s;}
.blob-2{width:380px;height:380px;background:#06b6d4;opacity:.28;bottom:-100px;right:-80px;animation-duration:12s;animation-delay:-5s;}
@@keyframes drift{0%{transform:translate(0,0) scale(1)}50%{transform:translate(26px,-16px) scale(1.06)}100%{transform:translate(-16px,26px) scale(.95)}}

.tutors-hero h1{
    position:relative;z-index:2;
    font-family:'Playfair Display',serif;
    font-size:clamp(42px,7vw,76px);font-weight:900;
    color:#fff;line-height:1.06;margin-bottom:18px;
    animation:fadeUp .7s ease both;
}
.tutors-hero h1 em{
    font-style:normal;
    background:linear-gradient(90deg,#a78bfa,#06b6d4,#e8f97d);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.tutors-hero p{
    position:relative;z-index:2;
    font-size:17px;color:rgba(255,255,255,.5);
    font-weight:300;max-width:480px;margin:0 auto 40px;line-height:1.8;
    animation:fadeUp .7s .1s ease both;
}
@@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* ── SEARCH BAR ── */
.search-bar{
    position:relative;z-index:2;
    display:flex;align-items:center;gap:0;
    max-width:600px;margin:0 auto;
    background:rgba(255,255,255,.09);
    border:1px solid rgba(255,255,255,.14);
    border-radius:999px;padding:6px 6px 6px 24px;
    backdrop-filter:blur(10px);
    animation:fadeUp .7s .2s ease both;
}
.search-bar input{
    flex:1;background:transparent;border:none;outline:none;
    color:#fff;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:300;
    padding:10px 0;
}
.search-bar input::placeholder{color:rgba(255,255,255,.3);}
.search-btn{
    padding:12px 28px;background:var(--accent2);
    color:#0d0a1e;border:none;border-radius:999px;
    font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;
    cursor:pointer;transition:opacity .2s;white-space:nowrap;
}
.search-btn:hover{opacity:.88;}

/* ── FILTER CHIPS ── */
.filter-row{
    position:relative;z-index:2;
    display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:22px;
    animation:fadeUp .7s .3s ease both;
}
.filter-chip{
    padding:8px 18px;border-radius:999px;
    border:1px solid rgba(255,255,255,.13);background:rgba(255,255,255,.05);
    color:rgba(255,255,255,.55);font-size:13px;cursor:pointer;transition:all .2s;
}
.filter-chip:hover,.filter-chip.active{background:var(--accent);border-color:var(--accent);color:#fff;}

/* ══════════════════════════════════════════
   TUTORS GRID
══════════════════════════════════════════ */
.tutors-section{
    padding:80px 24px 100px;background:var(--cream);
}
.tutors-inner{max-width:1140px;margin:auto;}
.tutors-header{
    display:flex;align-items:center;justify-content:space-between;
    margin-bottom:40px;flex-wrap:wrap;gap:12px;
}
.tutors-header h2{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:var(--ink);}
.tutors-header span{font-size:14px;color:#9998a8;}

.tutors-grid{
    display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:22px;
}

/* Tutor card */
.tutor-card{
    background:#fff;border-radius:24px;overflow:hidden;
    border:1px solid rgba(0,0,0,.07);
    transition:transform .3s,box-shadow .3s;
}
.tutor-card:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,.1);}

.tutor-card-top{
    height:110px;position:relative;
    display:flex;align-items:flex-end;padding:0 24px 0;
}
.tutor-card-top-bg{
    position:absolute;inset:0;
}
.tutor-avatar{
    position:relative;z-index:1;
    width:72px;height:72px;border-radius:50%;
    border:3px solid #fff;
    display:flex;align-items:center;justify-content:center;
    font-size:26px;font-weight:700;color:#fff;
    font-family:'Playfair Display',serif;
    transform:translateY(36px);
    flex-shrink:0;
}
.tutor-card-body{padding:48px 24px 24px;}
.tutor-name{font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:var(--ink);margin-bottom:3px;}
.tutor-subject{font-size:13px;color:#9998a8;margin-bottom:12px;}
.tutor-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;}
.tutor-tag{
    padding:4px 12px;border-radius:999px;font-size:12px;
    background:#f0eeff;color:#7c5cfc;font-weight:500;
}
.tutor-bio{font-size:14px;color:#7c7b8a;line-height:1.65;font-weight:300;margin-bottom:18px;}
.tutor-meta{
    display:flex;align-items:center;justify-content:space-between;
    padding-top:16px;border-top:1px solid rgba(0,0,0,.06);
}
.tutor-rating{font-size:14px;color:#f59e0b;font-weight:500;}
.tutor-rating span{color:#9998a8;font-weight:300;font-size:13px;}
.tutor-price{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--ink);}
.tutor-price small{font-family:'DM Sans',sans-serif;font-size:12px;color:#9998a8;font-weight:300;}
.tutor-btn{
    display:block;width:100%;padding:12px;margin-top:16px;
    background:linear-gradient(90deg,#7c5cfc,#06b6d4);
    color:#fff;border:none;border-radius:999px;
    font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;
    cursor:pointer;text-align:center;transition:opacity .2s;
    text-decoration:none;
}
.tutor-btn:hover{opacity:.88;color:#fff;}
</style>

<!-- ═══ NAVBAR ═══ -->
<nav class="navbar-custom">
    <a asp-action="Index" asp-controller="Home" class="nav-logo">
        <div class="nav-logo-icon">🎓</div>
        Tutor<span>Sphere</span>
    </a>
    <ul class="nav-links">
        <li><a asp-action="Index" asp-controller="Home">Home</a></li>
        <li><a asp-action="Index" asp-controller="Tutors">Tutors</a></li>
        <partial name="_AuthNav" />
        <li><a asp-action="Index" asp-controller="Booking" class="nav-cta">Book Now</a></li>
    </ul>
</nav>

<!-- ═══ HERO ═══ -->
<section class="tutors-hero">
    <div class="tutors-hero-bg"></div>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <h1>Find Your <em>Perfect</em><br/>Tutor Today</h1>
    <p>Browse 1,200+ verified tutors across 120+ subjects. Filter by rating, price, and availability.</p>

    <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search by subject, name, or keyword…" />
        <button class="search-btn" onclick="filterTutors()">Search →</button>
    </div>

    <div class="filter-row">
        <div class="filter-chip active" onclick="setFilter('All',this)">All Subjects</div>
        <div class="filter-chip" onclick="setFilter('Mathematics',this)">Mathematics</div>
        <div class="filter-chip" onclick="setFilter('Physics',this)">Physics</div>
        <div class="filter-chip" onclick="setFilter('Computer Science',this)">Computer Science</div>
        <div class="filter-chip" onclick="setFilter('English',this)">English</div>
        <div class="filter-chip" onclick="setFilter('Chemistry',this)">Chemistry</div>
    </div>
</section>

