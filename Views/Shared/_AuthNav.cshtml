@if (User.Identity?.IsAuthenticated == true)
{
    <li><span style="color:rgba(255,255,255,.75);font-size:14px;">Hi, @User.Identity.Name</span></li>
    <li>
        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;margin:0;">
            @Html.AntiForgeryToken()
            <button type="submit" style="background:none;border:none;color:rgba(255,255,255,.62);font-size:14px;cursor:pointer;padding:0;">Logout</button>
        </form>
    </li>
}
else
{
    <li><a asp-action="Login" asp-controller="Account">Login</a></li>
    <li><a asp-action="Register" asp-controller="Account" class="nav-cta">Register</a></li>
}
