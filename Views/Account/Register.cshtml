@model p1.Models.RegisterViewModel
@{
    ViewData["Title"] = "Student Registration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.navbar-custom{position:fixed;top:0;left:0;right:0;z-index:999;display:flex;align-items:center;justify-content:space-between;padding:18px 52px;background:rgba(13,10,30,0.55);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,0.07);}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#fff;}
.nav-logo-icon{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#7c5cfc,#06b6d4);display:flex;align-items:center;justify-content:center;font-size:20px;}
.nav-logo span{color:var(--accent2);}
.auth-page{min-height:100vh;background:#0d0a1e;display:flex;align-items:center;justify-content:center;padding:110px 24px 80px;position:relative;overflow:hidden;}
.auth-bg{position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=1600&q=80');background-size:cover;background-position:center;opacity:.05;}
.form-card{background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.11);border-radius:32px;padding:46px 42px;backdrop-filter:blur(22px);max-width:460px;width:100%;position:relative;z-index:2;}
.form-card h1{font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:#fff;margin-bottom:8px;}
.form-subtitle{font-size:14px;color:rgba(255,255,255,.38);margin-bottom:28px;font-weight:300;}
.field-group{margin-bottom:16px;}
.field-group label{display:block;font-size:11px;font-weight:500;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.42);margin-bottom:7px;}
.field-group input{width:100%;padding:13px 17px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:13px;color:#fff;font-family:'DM Sans',sans-serif;font-size:15px;outline:none;}
.field-group input:focus{border-color:rgba(124,92,252,.65);background:rgba(124,92,252,.1);}
.field-error{font-size:12px;color:#f87171;margin-top:5px;}
.validation-summary{color:#f87171;font-size:13px;margin-bottom:16px;}
.btn-confirm{width:100%;padding:17px;border:none;border-radius:999px;background:linear-gradient(90deg,#7c5cfc,#06b6d4);color:#fff;font-family:'DM Sans',sans-serif;font-size:16px;font-weight:500;cursor:pointer;margin-top:8px;}
.auth-footer{text-align:center;margin-top:20px;font-size:14px;color:rgba(255,255,255,.4);}
.auth-footer a{color:var(--accent2);}
</style>

<nav class="navbar-custom">
    <a asp-action="Index" asp-controller="Home" class="nav-logo">
        <div class="nav-logo-icon">🎓</div>
        Tutor<span>Sphere</span>
    </a>
</nav>

<div class="auth-page">
    <div class="auth-bg"></div>
    <div class="form-card">
        <h1>Create Account</h1>
        <p class="form-subtitle">Register as a student before booking a session</p>

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form asp-action="Register" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="field-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" placeholder="John Doe" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="you@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="field-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" placeholder="Repeat password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-confirm">Create Account →</button>
        </form>

        <p class="auth-footer">
            Already registered? <a asp-action="Login" asp-controller="Account" asp-route-returnUrl="@ViewData["ReturnUrl"]">Sign in here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
